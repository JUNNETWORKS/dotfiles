{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "timezone-converter",
  "title": "Timezone Converter",
  "description": "日時を指定タイムゾーンから別のタイムゾーンに変換します",
  "icon": "icon.png",
  "author": "you",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "convert-timezone",
      "title": "Convert Timezone",
      "description": "日時・変換元TZ・変換先TZを入力して変換",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.90.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/luxon": "^3.4.2",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  }
}
